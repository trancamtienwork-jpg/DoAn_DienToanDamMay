<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>
<%- include('partials/navbar') %>

<div class="container mt-5 pt-5">
    <% if (typeof message !== 'undefined' && message) { %>
        <%- message %>
    <% } %>

    <div class="card shadow-lg border-0 form-card">
        <div class="card-header form-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-pencil-square me-2"></i>Cập nhật xe</span>
            <a href="/xe" class="btn btn-outline-light btn-sm">
                <i class="bi bi-arrow-left me-1"></i>Quay lại
            </a>
        </div>

        <div class="card-body p-4">
            <form action="/xe/sua/<%= xe._id %>" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                <div class="row g-4">

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Tên xe</label>
                        <input type="text" name="TenXe" class="form-control" value="<%= xe.TenXe %>" required>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Dòng xe</label>
                        <select name="DongXe" class="form-select" required>
                            <option value="">-- Chọn dòng xe --</option>
                            <% dongxe.forEach(dx => { %>
                                <option value="<%= dx._id %>" <%= xe.DongXe.toString() === dx._id.toString() ? 'selected' : '' %>>
                                    <%= dx.TenDongXe %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Giá</label>
                        <div class="input-group">
                            <input type="number" name="Gia" class="form-control" value="<%= xe.Gia %>" required>
                            <span class="input-group-text">VNĐ</span>
                        </div>
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Năm sản xuất</label>
                        <input type="number" name="NamSanXuat" class="form-control" value="<%= xe.NamSanXuat %>">
                    </div>

                    <div class="col-md-4">
                        <label class="form-label fw-semibold">Màu sắc</label>
                        <input type="text" name="MauSac" class="form-control" value="<%= xe.MauSac %>">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Số lượng</label>
                        <input type="number" name="SoLuong" class="form-control" value="<%= xe.SoLuong %>" min="0">
                    </div>

                    <div class="col-md-6">
                        <label class="form-label fw-semibold">Nổi bật?</label>
                        <select name="NoiBat" class="form-select">
                            <option value="0" <%= xe.NoiBat == 0 ? 'selected' : '' %>>Không</option>
                            <option value="1" <%= xe.NoiBat == 1 ? 'selected' : '' %>>Có</option>
                        </select>
                    </div>

                    <!-- Upload ảnh -->
                    <div class="col-12">
                        <label class="form-label fw-semibold">Hình ảnh xe</label>

                        <div class="upload-box text-center p-4 upload-pro" onclick="document.getElementById('HinhAnhFile').click()">
                            <input type="file" id="HinhAnhFile" name="HinhAnhFile" accept="image/*" hidden>

                            <% if (xe.HinhAnh) { %>
                                <img id="previewImage" src="<%= xe.HinhAnh %>" class="img-fluid mt-2" style="max-height: 220px; border-radius: 14px; object-fit: cover;">
                                <div id="uploadText" class="mt-3">
                                    <p class="mb-1 fw-semibold">Nhấn để đổi ảnh khác</p>
                                    <small class="text-muted">Hỗ trợ JPG, PNG, WEBP</small>
                                </div>
                            <% } else { %>
                                <div id="uploadText">
                                    <i class="bi bi-cloud-arrow-up-fill fs-1 text-warning"></i>
                                    <p class="mt-3 mb-1 fw-semibold">Nhấn để chọn ảnh từ máy tính</p>
                                    <small class="text-muted">Hỗ trợ JPG, PNG, WEBP</small>
                                </div>
                                <img id="previewImage" class="img-fluid mt-3 d-none" style="max-height: 220px; border-radius: 14px; object-fit: cover;">
                            <% } %>
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label fw-semibold">Mô tả</label>
                        <textarea name="MoTa" rows="5" class="form-control"><%= xe.MoTa %></textarea>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4 flex-wrap">
                    <button type="submit" class="btn btn-warning px-4 btn-submit">
                        <i class="bi bi-save-fill me-2"></i>Lưu cập nhật
                    </button>
                    <a href="/xe" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-circle me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
<%- include('partials/javascript') %>

<script>
    const fileInput = document.getElementById('HinhAnhFile');
    const previewImage = document.getElementById('previewImage');
    const uploadText = document.getElementById('uploadText');

    fileInput.addEventListener('change', function () {
        const file = this.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = function (e) {
                previewImage.src = e.target.result;
                previewImage.classList.remove('d-none');

                if (uploadText) {
                    uploadText.innerHTML = `
                        <p class="mt-3 mb-1 fw-semibold">Nhấn để đổi ảnh khác</p>
                        <small class="text-muted">Hỗ trợ JPG, PNG, WEBP</small>
                    `;
                }
            };
            reader.readAsDataURL(file);
        }
    });
</script>

</body>
</html>