<!DOCTYPE html>
<html lang="vi">

<head>
    <%- include('partials/head') %>
</head>

<body>
    <%- include('partials/navbar') %>

        <main class="page-shell">
            <div class="container">
                <div class="page-hero-mini mb-4">
                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                        <div>
                            <span class="page-kicker">QUẢN LÝ</span>
                            <h1 class="page-title">Thanh toán</h1>
                            <p class="page-desc mb-0">
                                Theo dõi, tìm kiếm và xử lý các giao dịch thanh toán của khách hàng.
                            </p>
                        </div>

                        <div class="d-flex flex-wrap gap-3">
                            <div class="mini-stat-box">
                                <span class="mini-stat-label">Tổng giao dịch</span>
                                <strong>
                                    <%= thanhtoan.length %>
                                </strong>
                            </div>

                            <a href="/thanhtoan/them" class="btn btn-warning btn-premium">
                                <i class="bi bi-plus-circle me-2"></i>Thêm thanh toán
                            </a>
                        </div>
                    </div>
                </div>

                <%- message %>

                    <div class="premium-panel">
                        <div class="premium-panel-header">
                            <div
                                class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3">
                                <div>
                                    <h4 class="mb-1 fw-bold">Danh sách giao dịch</h4>
                                    <span class="table-meta-chip">
                                        <i class="bi bi-credit-card-2-front me-2"></i>Quản lý thanh toán
                                    </span>
                                </div>

                                <form method="get" action="/thanhtoan" class="w-100" style="max-width: 420px;">
                                    <div class="search-box-dongxe">
                                        <i class="bi bi-search search-icon"></i>
                                        <input type="text" class="form-control form-control-premium" name="tukhoa"
                                            id="searchInput" placeholder="Tìm mã GD, khách hàng, xe..."
                                            value="<%= tukhoa || '' %>" />
                                        <button type="button" class="btn-clear-search" id="clearSearchBtn">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </div>
                                </form>
                            </div>

                            <% if (tukhoa) { %>
                                <div class="mt-3 search-result-text">
                                    Kết quả tìm kiếm cho: <strong>
                                        <%= tukhoa %>
                                    </strong>
                                </div>
                                <% } %>
                        </div>

                        <div class="table-responsive premium-table-wrap">
                            <table class="table premium-table align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Giao dịch</th>
                                        <th>Khách hàng</th>
                                        <th>Xe</th>
                                        <th>Thanh toán</th>
                                        <th>Ngày TT</th>
                                        <th>Trạng thái</th>
                                        <th>Sửa</th>
                                        <th>Xóa</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (thanhtoan.length> 0) { %>
                                        <% thanhtoan.forEach((tt, index)=> {
                                            const giaXe = Number(
                                            tt.DatCoc?.Xe?.GiaBan ||
                                            tt.DatCoc?.Xe?.GiaXe ||
                                            tt.DatCoc?.Xe?.Gia ||
                                            tt.DatCoc?.Xe?.DonGia ||
                                            tt.DatCoc?.Xe?.GiaNiemYet ||
                                            0
                                            );

                                            const daCoc = Number(tt.DatCoc?.SoTienCoc || 0);
                                            const conLai = giaXe - daCoc;
                                            %>
                                            <tr>
                                                <td>
                                                    <span class="index-badge">
                                                        <%= index + 1 %>
                                                    </span>
                                                </td>

                                                <!-- GIAO DỊCH -->
                                                <td>
                                                    <div class="fw-bold">
                                                        <%= tt.MaGiaoDich || '---' %>
                                                    </div>
                                                    <small class="text-secondary">
                                                        Mã cọc: <%= tt.DatCoc?.MaDatCoc || '---' %>
                                                    </small>
                                                </td>

                                                <!-- KHÁCH -->
                                                <td>
                                                    <div class="fw-semibold">
                                                        <%= tt.DatCoc?.KhachHangRef?.HoVaTen || '---' %>
                                                    </div>
                                                    <small class="text-secondary">
                                                        <%= tt.DatCoc?.KhachHangRef?.SoDienThoai || '' %>
                                                    </small>
                                                </td>

                                                <!-- XE -->
                                                <td>
                                                    <div class="fw-semibold">
                                                        <%= tt.DatCoc?.Xe?.TenXe || '---' %>
                                                    </div>
                                                </td>

                                                <!-- THANH TOÁN -->
                                                <td>
                                                    <div class="price-text fw-bold">
                                                        <%= Number(tt.SoTien || 0).toLocaleString('vi-VN') %> đ
                                                    </div>
                                                    <small class="d-block text-secondary">
                                                        Giá gốc: <%= giaXe.toLocaleString('vi-VN') %> đ
                                                    </small>
                                                    <small class="d-block text-secondary">
                                                        Đã cọc: <%= daCoc.toLocaleString('vi-VN') %> đ
                                                    </small>
                                                    <small class="d-block text-secondary">
                                                        Còn lại: <%= conLai.toLocaleString('vi-VN') %> đ
                                                    </small>
                                                    <small class="d-block text-warning">
                                                        <i class="bi bi-wallet2 me-1"></i>
                                                        <%= tt.PhuongThuc || '---' %>
                                                    </small>
                                                </td>

                                                <!-- NGÀY -->
                                                <td>
                                                    <%= tt.NgayThanhToan ? new
                                                        Date(tt.NgayThanhToan).toLocaleDateString('vi-VN') : '---' %>
                                                </td>

                                                <!-- TRẠNG THÁI -->
                                                <td>
                                                    <a href="/thanhtoan/trangthai/<%= tt._id %>"
                                                        class="text-decoration-none">
                                                        <% if (tt.TrangThai==='ChoThanhToan' ) { %>
                                                            <span class="status-pill warning">
                                                                <i class="bi bi-hourglass-split me-1"></i>Chờ thanh toán
                                                            </span>
                                                            <% } else if (tt.TrangThai==='DaThanhToan' ) { %>
                                                                <span class="status-pill success">
                                                                    <i class="bi bi-check-circle-fill me-1"></i>Đã thanh
                                                                    toán
                                                                </span>
                                                                <% } else { %>
                                                                    <span class="status-pill danger">
                                                                        <i class="bi bi-x-circle-fill me-1"></i>Thất bại
                                                                    </span>
                                                                    <% } %>
                                                    </a>
                                                </td>
                                                <!-- SỬA -->
                                                <td>
                                                    <a href="/thanhtoan/sua/<%= tt._id %>" class="btn btn-action-edit">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </a>
                                                </td>

                                                <!-- XÓA -->
                                                <td>
                                                    <a href="/thanhtoan/xoa/<%= tt._id %>" class="btn btn-action-delete"
                                                        onclick="return confirm('Bạn có chắc muốn xóa giao dịch <%= tt.MaGiaoDich %> không?')">
                                                        <i class="bi bi-trash"></i>
                                                    </a>
                                                </td>
                                            </tr>
                                            <% }) %>
                                                <% } else { %>
                                                    <tr>
                                                        <td colspan="9" class="text-center py-5 text-secondary">
                                                            <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                                            Chưa có dữ liệu thanh toán.
                                                        </td>
                                                    </tr>
                                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
            </div>
        </main>

        <%- include('partials/footer') %>
            <%- include('partials/javascript') %>

                <script>
                    const searchInput = document.getElementById('searchInput');
                    const clearSearchBtn = document.getElementById('clearSearchBtn');

                    function toggleClearButton() {
                        clearSearchBtn.style.display = searchInput.value.trim() ? 'flex' : 'none';
                    }

                    searchInput.addEventListener('input', toggleClearButton);

                    clearSearchBtn.addEventListener('click', function () {
                        searchInput.value = '';
                        toggleClearButton();
                        window.location.href = '/thanhtoan';
                    });

                    toggleClearButton();
                </script>
</body>

</html>