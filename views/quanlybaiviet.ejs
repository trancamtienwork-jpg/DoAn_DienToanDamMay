<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>
<%- include('partials/navbar') %>

<div class="container page-shell">
    <% if (typeof message !== 'undefined' && message) { %>
        <div class="mb-4 mt-3">
            <%- message %>
        </div>
    <% } %>

    <section class="page-hero-mini mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-4">
            <div>
                <span class="page-kicker">ADMIN CMS</span>
                <h1 class="page-title mb-2">Quản lý bài viết</h1>
                <p class="page-desc mb-0">Quản lý nội dung bài viết trên toàn hệ thống.</p>
            </div>

            <div class="d-flex gap-3 flex-wrap">
                <div class="mini-stat-box">
                    <span class="mini-stat-label"><i class="bi bi-file-earmark-richtext me-1"></i>Tổng bài</span>
                    <strong><%= baiviet.length %></strong>
                </div>
            </div>
        </div>
    </section>

    <section class="premium-panel p-4 mb-4">
        <form method="GET" action="/baiviet/quanly" class="row g-3 align-items-end">
            <div class="col-md-7">
                <label class="form-label fw-semibold">Tìm kiếm bài viết</label>
                <input type="text" name="tukhoa" class="form-control" value="<%= tuKhoa %>" placeholder="Nhập tiêu đề bài viết...">
            </div>

            <div class="col-md-3">
                <label class="form-label fw-semibold">Trạng thái duyệt</label>
                <select name="kiemduyet" class="form-select">
                    <option value="">Tất cả</option>
                    <option value="1" <%= boLocKiemDuyet == '1' ? 'selected' : '' %>>Đã duyệt</option>
                    <option value="0" <%= boLocKiemDuyet == '0' ? 'selected' : '' %>>Chờ duyệt</option>
                </select>
            </div>

            <div class="col-md-2 d-grid">
                <button class="btn btn-warning">
                    <i class="bi bi-search me-2"></i>Tìm
                </button>
            </div>
        </form>
    </section>

    <section class="premium-panel">
        <div class="premium-panel-header d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <h4 class="fw-bold mb-1">
                    <i class="bi bi-journal-richtext text-warning me-2"></i>Danh sách bài viết
                </h4>
                <p class="page-desc mb-0">Quản trị toàn bộ nội dung hệ thống.</p>
            </div>

            <a href="/baiviet/them" class="btn btn-warning">
                <i class="bi bi-plus-circle me-2"></i>Thêm bài viết
            </a>
        </div>

        <% if (baiviet && baiviet.length > 0) { %>
            <div class="table-responsive premium-table-wrap">
                <table class="table premium-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Ảnh</th>
                            <th>Tiêu đề</th>
                            <th>Tác giả</th>
                            <th>Nổi bật</th>
                            <th>Lượt xem</th>
                            <th>Ngày đăng</th>
                            <th>Duyệt</th>
                            <th>Sửa</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% let stt = 1; %>
                        <% baiviet.forEach((bv) => { %>
                            <tr>
                                <td><span class="index-badge"><%= stt++ %></span></td>

                                <td>
                                    <% if (bv.HinhAnh) { %>
                                        <img src="<%= bv.HinhAnh %>" class="table-car-image" alt="<%= bv.TieuDe %>">
                                    <% } else { %>
                                        <div class="no-image-box">Không ảnh</div>
                                    <% } %>
                                </td>

                                <td class="text-start">
                                    <div class="fw-bold"><%= bv.TieuDe %></div>
                                    <small class="text-secondary"><%= bv.TomTat ? bv.TomTat.substring(0, 60) : 'Không có tóm tắt' %>...</small>
                                </td>

                                <td><%= bv.TacGia ? bv.TacGia.HoVaTen : 'Ẩn danh' %></td>

                                <td>
                                    <% if (bv.NoiBat == 1) { %>
                                        <span class="badge-premium">Có</span>
                                    <% } else { %>
                                        <span class="year-pill">Không</span>
                                    <% } %>
                                </td>

                                <td><span class="price-text"><%= bv.LuotXem || 0 %></span></td>

                                <td><%= new Date(bv.NgayDang).toLocaleDateString('vi-VN') %></td>

                                <td>
                                    <a href="/baiviet/duyet/<%= bv._id %>" class="btn btn-sm <%= bv.KiemDuyet == 1 ? 'btn-outline-success' : 'btn-outline-danger' %>">
                                        <%= bv.KiemDuyet == 1 ? 'Đã duyệt' : 'Chờ duyệt' %>
                                    </a>
                                </td>

                                <td>
                                    <a href="/baiviet/sua/<%= bv._id %>" class="btn-action-edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                </td>

                                <td>
                                    <a href="/baiviet/xoa/<%= bv._id %>" class="btn-action-delete"
                                       onclick="return confirm('Bạn có muốn xóa bài viết <%= bv.TieuDe %> không?');">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } else { %>
            <div class="p-5 text-center">
                <i class="bi bi-file-earmark-x fs-1 text-warning d-block mb-3"></i>
                <h5 class="fw-bold">Chưa có bài viết nào</h5>
                <p class="section-subtitle mb-0">Hệ thống hiện chưa có bài viết để quản lý.</p>
            </div>
        <% } %>
    </section>
</div>

<%- include('partials/footer') %>
<%- include('partials/javascript') %>
</body>
</html>