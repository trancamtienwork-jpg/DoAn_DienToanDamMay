<!DOCTYPE html>
<html lang="vi">
<head><%- include('partials/head') %></head>
<body>
<%- include('partials/navbar') %>

<div class="container mt-4">
    <%- message %>

    <div class="card shadow-lg">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-people-fill me-2"></i>Danh sách tài khoản</span>
            <a href="/taikhoan/them" class="btn btn-warning btn-sm">
                <i class="bi bi-plus-circle-fill me-1"></i> Thêm tài khoản
            </a>
        </div>

        <div class="card-body table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Họ và tên</th>
                        <th>Email</th>
                        <th>Tên đăng nhập</th>
                        <th>Quyền hạn</th>
                        <th>Trạng thái</th>
                        <th>Sửa</th>
                        <th>Xóa</th>
                    </tr>
                </thead>
                <tbody>
                    <% taikhoan.forEach((tk, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= tk.HoVaTen %></td>
                            <td><%= tk.Email || '---' %></td>
                            <td><%= tk.TenDangNhap %></td>
                            <td><%= tk.QuyenHan %></td>
                            <td><%= tk.KichHoat == 1 ? 'Kích hoạt' : 'Khóa' %></td>
                            <td>
                                <a href="/taikhoan/sua/<%= tk._id %>" class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                            </td>
                            <td>
                                <a href="/taikhoan/xoa/<%= tk._id %>" class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Bạn có chắc muốn xóa tài khoản này?')">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
<%- include('partials/javascript') %>
</body>
</html>