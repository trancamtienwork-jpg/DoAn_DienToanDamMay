<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>
    <%- include('partials/navbar') %>

    <main class="page-shell">
        <div class="container" style="max-width: 980px;">
            <div class="page-hero-mini mb-4">
                <span class="page-kicker">THÊM MỚI</span>
                <h1 class="page-title">Phiếu đặt cọc</h1>
                <p class="page-desc mb-0">Nhập thông tin đặt cọc cho khách hàng.</p>
            </div>

            <%- message %>

            <div class="glass-card p-4 p-lg-5">
                <form action="/datcoc/them" method="post" class="needs-validation" novalidate>
                    <div class="row g-4">
                        <div class="col-md-6">
                            <label class="form-label">Khách hàng</label>
                            <select name="KhachHang" class="form-select" required>
                                <option value="">-- Chọn khách hàng --</option>
                                <% taikhoan.forEach(tk => { %>
                                    <option value="<%= tk._id %>"><%= tk.HoVaTen %> - <%= tk.TenDangNhap %></option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Xe</label>
                            <select name="Xe" class="form-select" required>
                                <option value="">-- Chọn xe --</option>
                                <% xe.forEach(x => { %>
                                    <option value="<%= x._id %>">
                                        <%= x.TenXe %> <% if(x.DongXe){ %> - <%= x.DongXe.TenDongXe %> <% } %>
                                    </option>
                                <% }) %>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Số tiền cọc</label>
                            <input type="number" name="SoTienCoc" class="form-control" placeholder="Ví dụ: 50000000" required>
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Ngày đặt</label>
                            <input type="date" name="NgayDat" class="form-control">
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Trạng thái</label>
                            <select name="TrangThai" class="form-select">
                                <option value="ChoXuLy">Chờ xử lý</option>
                                <option value="DaXacNhan">Đã xác nhận</option>
                                <option value="DaHuy">Đã hủy</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label">Ghi chú</label>
                            <textarea name="GhiChu" class="form-control" rows="4" placeholder="Nhập ghi chú thêm..."></textarea>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-3 mt-4">
                        <button type="submit" class="btn btn-warning btn-premium">
                            <i class="bi bi-plus-circle me-2"></i>Thêm đặt cọc
                        </button>
                        <a href="/datcoc" class="btn btn-outline-light">
                            <i class="bi bi-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </main>

    <%- include('partials/footer') %>
    <%- include('partials/javascript') %>
</body>
</html>