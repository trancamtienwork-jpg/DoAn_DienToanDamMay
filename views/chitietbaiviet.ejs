<!DOCTYPE html>
<html lang="vi">
<head>
    <%- include('partials/head') %>
</head>
<body>
<%- include('partials/navbar') %>

<div class="container page-shell">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="premium-panel p-4 p-lg-5">
                <% if (baiviet.HinhAnh) { %>
                    <img src="<%= baiviet.HinhAnh %>" class="img-fluid rounded-4 mb-4 w-100" style="max-height: 420px; object-fit: cover;">
                <% } %>

                <div class="mb-3">
                    <% if (baiviet.NoiBat == 1) { %>
                        <span class="badge-premium">Bài viết nổi bật</span>
                    <% } %>
                </div>

                <h1 class="fw-bold mb-3"><%= baiviet.TieuDe %></h1>

                <div class="d-flex flex-wrap gap-3 mb-4 text-secondary">
                    <span><i class="bi bi-person me-2"></i><%= baiviet.TacGia ? baiviet.TacGia.HoVaTen : 'Ẩn danh' %></span>
                    <span><i class="bi bi-calendar-event me-2"></i><%= new Date(baiviet.NgayDang).toLocaleString('vi-VN') %></span>
                    <span><i class="bi bi-eye me-2"></i><%= baiviet.LuotXem || 0 %> lượt xem</span>
                </div>

                <div class="glass-card p-4 mb-4">
                    <h5 class="fw-bold mb-2 text-warning">Tóm tắt</h5>
                    <p class="mb-0"><%= baiviet.TomTat %></p>
                </div>

                <div class="article-content">
                    <%- baiviet.NoiDung.replace(/\n/g, '<br>') %>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="premium-panel p-4">
                <h4 class="fw-bold mb-4">
                    <i class="bi bi-collection-play text-warning me-2"></i>Bài viết liên quan
                </h4>

                <% if (baivietlienquan && baivietlienquan.length > 0) { %>
                    <div class="d-flex flex-column gap-3">
                        <% baivietlienquan.forEach(item => { %>
                            <a href="/baiviet/chi-tiet/<%= item._id %>" class="text-white">
                                <div class="glass-card p-3 d-flex gap-3 align-items-center">
                                    <img src="<%= item.HinhAnh || 'https://via.placeholder.com/120x90?text=Bai+Viet' %>"
                                         style="width: 100px; height: 70px; object-fit: cover; border-radius: 12px;">
                                    <div>
                                        <div class="fw-bold mb-1"><%= item.TieuDe %></div>
                                        <small class="text-secondary"><%= new Date(item.NgayDang).toLocaleDateString('vi-VN') %></small>
                                    </div>
                                </div>
                            </a>
                        <% }) %>
                    </div>
                <% } else { %>
                    <p class="text-secondary mb-0">Không có bài viết liên quan.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
<%- include('partials/javascript') %>
</body>
</html>